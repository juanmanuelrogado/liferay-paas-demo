{
	"cpu": 1,
    "memory": 4096,
	"env": {
	        "LIFERAY_ROUTES_CLIENT_EXTENSION": "/etc/liferay/lxc/ext-init-metadata",
	        "LIFERAY_ROUTES_DXP": "/etc/liferay/lxc/dxp-metadata",
	        "LCP_CMSCHAT_OPENAI_KEY": "@lcp-secret-cmschat-openai-key"
	},	"environments": {
		"infra": {
			"deploy": false
		}
	},
	"id": "cmschat",
	"kind": "Deployment",
	"livenessProbe": {
		"httpGet": {
			"path": "/ready",
			"port": 58081
		}
	},
	"loadBalancer": {
		"targetPort": 58081
	},
	"readinessProbe": {
		"httpGet": {
			"path": "/ready",
			"port": 58081
		}
	},
	"scale": 1
}